# Image selection
ARTEMIS_IMAGE_PREFIX=artemis
ARTEMIS_IMAGE_TAG=latest

# Public edge
APP_DOMAIN=artemis.example.com

# Shared service auth
INTERNAL_API_TOKEN=replace-with-random-32-byte-token
METRICS_TOKEN=replace-with-separate-random-token

# PostgreSQL
# Runtime API credential should be the limited artemis_app role.
DATABASE_URL=postgresql://artemis_app:password@db.example.com:5432/artemis?sslmode=require&connection_limit=5
# Migration credential should have schema ownership/DDL rights for Prisma and pg-boss migrations.
DATABASE_MIGRATION_URL=postgresql://artemis_migration:password@db.example.com:5432/artemis?sslmode=require
DATABASE_POOL_MAX=5
DATABASE_PLAN_MAX_CONNECTIONS=25
DATABASE_CONNECTION_ALERT_THRESHOLD=0.7
PGBOSS_POOL_MAX=2
PGBOSS_SCHEMA=pgboss

# Discord bot and OAuth
DISCORD_TOKEN=replace-me
DISCORD_CLIENT_ID=replace-me
DISCORD_CLIENT_SECRET=replace-me
DISCORD_GUILD_ID=replace-me
DISCORD_EVENT_CHANNEL_ID=replace-me
ARTEMIS_EVENT_TIME_ZONE=America/New_York
DASHBOARD_ALLOWED_ROLE_IDS=role_id_1,role_id_2
DISCORD_REDIRECT_URI=https://artemis.example.com/api/auth/callback

# Web dashboard
SESSION_SECRET=replace-with-random-32-byte-secret
WEB_APP_URL=https://artemis.example.com

# Optional integrations
DISCORD_OPS_WEBHOOK_URL=
FEEDBACK_FORM_URL=

# Logical backups
OBJECT_STORAGE_ENDPOINT=https://us-east-1.linodeobjects.com
OBJECT_STORAGE_BUCKET=artemis-backups
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
BACKUP_ENCRYPTION_PASSPHRASE=
